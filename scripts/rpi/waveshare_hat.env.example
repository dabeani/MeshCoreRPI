MESHCORE_RPI_RADIO=sx1262

# Waveshare SX1262 LoRa HAT default wiring on Raspberry Pi (SPI version).
MESHCORE_RPI_SPI_BUS=0
MESHCORE_RPI_SPI_CS=0
MESHCORE_RPI_CS_PIN=21
MESHCORE_RPI_RESET_PIN=18
MESHCORE_RPI_BUSY_PIN=20
MESHCORE_RPI_IRQ_PIN=16
MESHCORE_RPI_TXEN_PIN=-1
MESHCORE_RPI_RXEN_PIN=-1
MESHCORE_RPI_USE_DIO3_TCXO=false

# Mesh defaults (adjust to your region).
MESHCORE_RPI_FREQUENCY_HZ=869525000
MESHCORE_RPI_BANDWIDTH_HZ=250000
MESHCORE_RPI_SPREADING_FACTOR=11
MESHCORE_RPI_CODING_RATE=5
MESHCORE_RPI_TX_POWER_DBM=22
MESHCORE_RPI_PREAMBLE_LEN=16
